generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native"]
}

datasource db {
  provider = "postgresql"
}

model academic_awards {
  id                   String              @id @db.Uuid
  background_id        String              @db.Uuid
  award_name           String              @db.VarChar(255)
  issuing_organization String?             @db.VarChar(255)
  award_level          String?             @db.VarChar(100)
  award_date           DateTime?           @db.Date
  description          String?
  certificate_url      String?
  created_at           DateTime?           @default(now()) @db.Timestamp(6)
  updated_at           DateTime?           @default(now()) @db.Timestamp(6)
  category             String?             @db.VarChar(50)
  rank                 Int?
  region               String?             @db.VarChar(50)
  year                 Int?
  student_backgrounds  student_backgrounds @relation(fields: [background_id], references: [student_id], onDelete: Cascade)

  @@index([background_id])
}

model academic_extracurriculars {
  id                  String              @id @db.Uuid
  background_id       String              @db.Uuid
  activity_name       String              @db.VarChar(255)
  organization        String?             @db.VarChar(255)
  role                String?             @db.VarChar(100)
  start_date          DateTime?           @db.Date
  end_date            DateTime?           @db.Date
  hours_per_week      Int?
  weeks_per_year      Int?
  description         String?
  achievements        String?
  related_to_major    Boolean?            @default(true)
  created_at          DateTime?           @default(now()) @db.Timestamp(6)
  updated_at          DateTime?           @default(now()) @db.Timestamp(6)
  region              String?             @db.VarChar(50)
  scale               Int?
  impact_tier         Int?
  student_backgrounds student_backgrounds @relation(fields: [background_id], references: [student_id], onDelete: Cascade)

  @@index([background_id])
}

model chat_attachments {
  id            String        @id @db.Uuid
  message_id    String        @db.Uuid
  file_url      String
  file_name     String        @db.VarChar(255)
  file_type     String        @db.VarChar(100)
  file_size     BigInt?
  thumbnail_url String?
  created_at    DateTime      @default(now()) @db.Timestamp(6)
  chat_messages chat_messages @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@index([file_type])
  @@index([message_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chat_messages {
  id               String             @id @db.Uuid
  room_id          String             @db.Uuid
  sender_id        String             @db.Uuid
  content          String?
  type             MessageType        @default(TEXT)
  created_at       DateTime           @default(now()) @db.Timestamp(6)
  updated_at       DateTime           @default(now()) @db.Timestamp(6)
  deleted_at       DateTime?          @db.Timestamp(6)
  is_edited        Boolean            @default(false)
  chat_attachments chat_attachments[]
  chat_rooms       chat_rooms         @relation(fields: [room_id], references: [id], onDelete: Cascade)
  users            users              @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([room_id])
  @@index([sender_id])
}

model chat_participants {
  id           String     @id @db.Uuid
  room_id      String     @db.Uuid
  user_id      String     @db.Uuid
  last_read_at DateTime?  @db.Timestamp(6)
  joined_at    DateTime   @default(now()) @db.Timestamp(6)
  left_at      DateTime?  @db.Timestamp(6)
  is_active    Boolean    @default(true)
  chat_rooms   chat_rooms @relation(fields: [room_id], references: [id], onDelete: Cascade)
  users        users      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([room_id, user_id])
  @@index([room_id])
  @@index([user_id])
}

model chat_rooms {
  id                String              @id @db.Uuid
  name              String              @db.VarChar(255)
  type              RoomType
  status            RoomStatus          @default(ACTIVE)
  student_id        String              @db.Uuid
  mentor_type       MentorType?
  created_at        DateTime            @default(now()) @db.Timestamp(6)
  updated_at        DateTime            @default(now()) @db.Timestamp(6)
  deleted_at        DateTime?           @db.Timestamp(6)
  chat_messages     chat_messages[]
  chat_participants chat_participants[]
  users             users               @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([student_id])
  @@index([type])
}

model checklist_stages {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(100)
  description     String?
  order_index     Int               @unique
  is_default      Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamp(6)
  updated_at      DateTime          @default(now()) @db.Timestamp(6)
  checklist_tasks checklist_tasks[]
}

model checklist_tasks {
  id                    String                  @id @db.Uuid
  stage_id              Int
  title                 String                  @db.VarChar(500)
  description           String?
  link_to               String?
  order_index           Int
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  updated_at            DateTime                @default(now()) @db.Timestamp(6)
  is_required           Boolean                 @default(true)
  checklist_stages      checklist_stages        @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  student_task_progress student_task_progress[]
}

model consultation_meetings {
  id               String   @id @db.Uuid
  title            String   @db.VarChar(255)
  mentor_id        String   @db.Uuid
  student_email    String   @db.VarChar(255)
  start_time       DateTime @db.Timestamp(6)
  end_time         DateTime @db.Timestamp(6)
  meet_link        String?  @db.VarChar(500)
  google_event_id  String?  @db.VarChar(255)
  description      String?
  created_at       DateTime @default(now()) @db.Timestamp(6)
  mentor_email     String   @db.VarChar(255)
  duration_minutes Int      @default(60)
  host_meet_link   String?  @db.VarChar(500)
  student_id       String?  @db.Uuid
  mentor_user      users    @relation("MentorMeetings", fields: [mentor_id], references: [id], onDelete: Cascade)
  student_user     users?   @relation("StudentMeetings", fields: [student_id], references: [id])

  @@index([mentor_id])
  @@index([student_id])
  @@index([start_time])
  @@index([student_email])
}

model cv_improve_results {
  id              String    @id @db.Uuid
  student_id      String    @unique @db.Uuid
  analysis_result Json?
  enhance_result  Json?
  analysis_rating Int?
  enhance_rating  Int?
  analysis_at     DateTime? @db.Timestamp(6)
  enhance_at      DateTime? @db.Timestamp(6)
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  updated_at      DateTime  @default(now()) @db.Timestamp(6)
  students        students  @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([student_id])
}

model essay_comments {
  id           String   @id @db.Uuid
  essay_id     String   @db.Uuid
  author_id    String   @db.Uuid
  content      String
  start_offset Int?
  end_offset   Int?
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @default(now()) @db.Timestamp(6)
  users        users    @relation(fields: [author_id], references: [id], onDelete: Cascade)
  essays       essays   @relation(fields: [essay_id], references: [id], onDelete: Cascade)

  @@index([author_id])
  @@index([essay_id])
}

model essay_improve_results {
  id              String    @id @db.Uuid
  essay_id        String    @unique @db.Uuid
  analysis_result Json?
  enhance_result  Json?
  analysis_rating Int?
  enhance_rating  Int?
  analysis_at     DateTime? @db.Timestamp(6)
  enhance_at      DateTime? @db.Timestamp(6)
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  updated_at      DateTime  @default(now()) @db.Timestamp(6)
  essays          essays    @relation(fields: [essay_id], references: [id], onDelete: Cascade)

  @@index([essay_id])
}

model essays {
  id                    String                 @id @db.Uuid
  student_id            String                 @db.Uuid
  title                 String?                @db.VarChar(500)
  content               String
  created_at            DateTime               @default(now()) @db.Timestamp(6)
  updated_at            DateTime               @default(now()) @db.Timestamp(6)
  essay_comments        essay_comments[]
  essay_improve_results essay_improve_results?
  students              students               @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([student_id])
}

model faculty {
  id            String       @id @db.Uuid
  university_id Int
  name          String       @db.VarChar(255)
  description   String?
  type          String?      @db.VarChar(100)
  url_web       String?      @db.VarChar(500)
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  updated_at    DateTime?    @default(now()) @db.Timestamp(6)
  universities  universities @relation(fields: [university_id], references: [id], onDelete: Cascade)

  @@index([university_id])
}

model grit_tests {
  id                 String     @id @db.Uuid
  student_id         String     @unique @db.Uuid
  status             TestStatus @default(IN_PROGRESS)
  current_step       Int        @default(0)
  answers            Json       @default("{}")
  total_score        Float?
  level              String?    @db.VarChar(50)
  description        String?
  completed_at       DateTime?  @db.Timestamp(6)
  updated_at         DateTime?  @default(now()) @db.Timestamp(6)
  passion_score      Float?
  perseverance_score Float?
  students           students   @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
}

model improve_jobs {
  id              String    @id @db.Uuid
  student_id      String    @db.Uuid
  job_type        String    @db.VarChar(50)
  external_job_id String?   @db.VarChar(255)
  essay_id        String?   @db.Uuid
  status          String    @db.VarChar(20)
  started_at      DateTime  @default(now()) @db.Timestamp(6)
  completed_at    DateTime? @db.Timestamp(6)
  error_message   String?
  students        students  @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([status])
  @@index([student_id])
  @@index([student_id, status])
}

model leads {
  id                  String   @id @db.Uuid
  full_name           String   @db.VarChar(100)
  phone               String   @db.VarChar(20)
  email               String   @db.VarChar(255)
  current_location    String?  @db.VarChar(255)
  current_school      String?  @db.VarChar(255)
  current_grade       String?  @db.VarChar(50)
  study_level         String?  @db.VarChar(100)
  intended_major      String?  @db.VarChar(255)
  intended_country    String?  @db.VarChar(100)
  intended_university String?  @db.VarChar(255)
  budget_per_year     String?  @db.VarChar(100)
  status              String   @default("NEW") @db.VarChar(50)
  notes               String?
  created_at          DateTime @default(now()) @db.Timestamp(6)

  @@index([created_at])
  @@index([email])
  @@index([status])
}

model mbti_tests {
  id                 String     @id @db.Uuid
  student_id         String     @unique @db.Uuid
  status             TestStatus @default(IN_PROGRESS)
  current_step       Int        @default(0)
  answers            Json       @default("[]")
  result_type        String?    @db.VarChar(10)
  score_e            Float?
  score_i            Float?
  score_s            Float?
  score_n            Float?
  score_t            Float?
  score_f            Float?
  score_j            Float?
  score_p            Float?
  completed_at       DateTime?  @db.Timestamp(6)
  updated_at         DateTime?  @default(now()) @db.Timestamp(6)
  result_description String?
  students           students   @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
}

model mentor_assignments {
  id          String           @id @db.Uuid
  student_id  String           @db.Uuid
  assigned_at DateTime         @default(now()) @db.Timestamp(6)
  mentor_id   String           @db.Uuid
  status      AssignmentStatus @default(ACTIVE)
  type        MentorType
  mentors     mentors          @relation(fields: [mentor_id], references: [user_id], onDelete: Cascade, map: "mentor_assignments_mentor_profile_fkey")
  users       users            @relation(fields: [mentor_id], references: [id], onDelete: Cascade, map: "mentor_assignments_mentor_user_fkey")
  students    students         @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@unique([student_id, type])
  @@index([mentor_id])
  @@index([student_id])
}

model mentor_custom_deadlines {
  id           String     @id @db.Uuid
  student_id   String     @db.Uuid
  mentor_id    String     @db.Uuid
  title        String     @db.VarChar(500)
  description  String?
  deadline     DateTime?  @db.Timestamp(6)
  status       TaskStatus @default(PENDING)
  created_at   DateTime   @default(now()) @db.Timestamp(6)
  updated_at   DateTime   @db.Timestamp(6)
  student_note String?
  mentor_note  String?
  mentors      mentors    @relation(fields: [mentor_id], references: [user_id], onDelete: Cascade)
  students     students   @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([deadline])
  @@index([mentor_id])
  @@index([student_id])
}

model mentors {
  user_id                  String                    @id @db.Uuid
  bio                      String?
  linkedin_url             String?                   @db.VarChar(255)
  website_url              String?                   @db.VarChar(255)
  university_name          String?                   @db.VarChar(255)
  degree                   String?                   @db.VarChar(100)
  major                    String?                   @db.VarChar(100)
  graduation_year          Int?
  current_company          String?                   @db.VarChar(150)
  current_job_title        String?                   @db.VarChar(150)
  years_of_experience      Int?                      @default(0)
  expertises               Json?                     @default("[]")
  outstanding_achievements Json?                     @default("[]")
  is_accepting_students    Boolean?                  @default(true)
  max_students             Int?                      @default(5)
  rating                   Float?                    @default(5.0)
  created_at               DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                 @default(now()) @db.Timestamp(6)
  specialization           MentorType
  mentor_assignments       mentor_assignments[]
  mentor_custom_deadlines  mentor_custom_deadlines[]
  users                    users                     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model non_academic_awards {
  id                   String              @id @db.Uuid
  background_id        String              @db.Uuid
  award_name           String              @db.VarChar(255)
  category             String?             @db.VarChar(100)
  issuing_organization String?             @db.VarChar(255)
  award_level          String?             @db.VarChar(100)
  award_date           DateTime?           @db.Date
  description          String?
  certificate_url      String?
  created_at           DateTime?           @default(now()) @db.Timestamp(6)
  updated_at           DateTime?           @default(now()) @db.Timestamp(6)
  rank                 Int?
  region               String?             @db.VarChar(50)
  year                 Int?
  student_backgrounds  student_backgrounds @relation(fields: [background_id], references: [student_id], onDelete: Cascade)

  @@index([background_id])
}

model non_academic_extracurriculars {
  id                  String              @id @db.Uuid
  background_id       String              @db.Uuid
  activity_name       String              @db.VarChar(255)
  category            String?             @db.VarChar(100)
  organization        String?             @db.VarChar(255)
  role                String?             @db.VarChar(100)
  start_date          DateTime?           @db.Date
  end_date            DateTime?           @db.Date
  hours_per_week      Int?
  weeks_per_year      Int?
  description         String?
  achievements        String?
  impact              String?
  created_at          DateTime?           @default(now()) @db.Timestamp(6)
  updated_at          DateTime?           @default(now()) @db.Timestamp(6)
  region              String?             @db.VarChar(50)
  scale               Int?
  student_backgrounds student_backgrounds @relation(fields: [background_id], references: [student_id], onDelete: Cascade)

  @@index([background_id])
}

model password_reset_tokens {
  id         String   @id @db.Uuid
  email      String   @unique @db.VarChar(255)
  token      String   @unique @db.VarChar(255)
  expires    DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)

  @@index([email])
  @@index([token])
}

model personal_projects {
  id                  String              @id @db.Uuid
  background_id       String              @db.Uuid
  project_name        String              @db.VarChar(255)
  topic               String?             @db.VarChar(100)
  description         String?
  duration_months     Int?
  impact              String?
  tier                Int?
  created_at          DateTime?           @default(now()) @db.Timestamp(6)
  updated_at          DateTime?           @default(now()) @db.Timestamp(6)
  student_backgrounds student_backgrounds @relation(fields: [background_id], references: [student_id], onDelete: Cascade)

  @@index([background_id])
}

/// Kết quả phân tích hồ sơ (logic mới). Spike và chi tiết lấy từ full_result.
model profile_analyses {
  id          String    @id @db.Uuid
  student_id  String    @db.Uuid
  full_result Json      @default("{}")
  swot_data   Json?     @default("{}")
  input_data  Json      @default("{}")
  score_aca   Float?
  score_lan   Float?
  score_hdnk  Float?
  score_skill Float?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  students    students  @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([student_id])
  @@index([student_id, created_at])
}

model profile_analysis_jobs {
  id            String    @id @db.Uuid
  student_id    String    @db.Uuid
  status        String    @db.VarChar(20)
  started_at    DateTime  @default(now()) @db.Timestamp(6)
  completed_at  DateTime? @db.Timestamp(6)
  error_message String?
  students      students  @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([status])
  @@index([student_id])
}

model profile_improve_results {
  id              String    @id @db.Uuid
  student_id      String    @db.Uuid
  analysis_result Json?
  enhance_result  Json?
  analysis_rating Int?
  enhance_rating  Int?
  analysis_at     DateTime? @db.Timestamp(6)
  enhance_at      DateTime? @db.Timestamp(6)
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  updated_at      DateTime  @default(now()) @db.Timestamp(6)
  students        students  @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([student_id])
  @@index([student_id, created_at])
}

model faculty_recommendations {
  id                  String    @id @db.Uuid
  student_id          String    @db.Uuid
  assessment_summary  Json?
  faculties           Json?
  created_at          DateTime  @default(now()) @db.Timestamp(6)
  students            students  @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([student_id])
  @@index([student_id, created_at])
}

model faculty_wishlist {
  id          String   @id @db.Uuid
  student_id  String   @db.Uuid
  faculty_name String @db.VarChar(500)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  students    students @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([student_id])
}

model school_wishlist {
  id            String              @id @db.Uuid
  student_id    String              @db.Uuid
  university_id Int
  sort_order    Int                 @default(0)
  created_at    DateTime            @default(now()) @db.Timestamp(6)
  students      students            @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
  university_rankings university_rankings @relation(fields: [university_id], references: [id], onDelete: Cascade)

  @@unique([student_id, university_id])
  @@index([student_id])
}

model admission_chance_results {
  id         String   @id @db.Uuid
  student_id String   @db.Uuid
  summary    Json     @default("{}")
  faculties  Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamp(6)
  students   students @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([student_id])
  @@index([student_id, created_at])
}

model research_experiences {
  id                  String              @id @db.Uuid
  background_id       String              @db.Uuid
  project_title       String              @db.VarChar(255)
  institution         String?             @db.VarChar(255)
  supervisor_name     String?             @db.VarChar(150)
  role                String?             @db.VarChar(100)
  start_date          DateTime?           @db.Date
  end_date            DateTime?           @db.Date
  is_current          Boolean?            @default(false)
  research_field      String?             @db.VarChar(255)
  description         String?
  methodologies       String?
  findings            String?
  publication_url     String?
  created_at          DateTime?           @default(now()) @db.Timestamp(6)
  updated_at          DateTime?           @default(now()) @db.Timestamp(6)
  student_backgrounds student_backgrounds @relation(fields: [background_id], references: [student_id], onDelete: Cascade)

  @@index([background_id])
}

model riasec_tests {
  id                  String     @id @db.Uuid
  student_id          String     @unique @db.Uuid
  status              TestStatus @default(IN_PROGRESS)
  current_step        Int        @default(0)
  answers             Json       @default("{}")
  result_code         String?    @db.VarChar(10)
  score_realistic     Float?
  score_investigative Float?
  score_artistic      Float?
  score_social        Float?
  score_enterprising  Float?
  score_conventional  Float?
  top_3_types         Json?      @default("[]")
  completed_at        DateTime?  @db.Timestamp(6)
  updated_at          DateTime?  @default(now()) @db.Timestamp(6)
  result_description  String?
  students            students   @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
}

model scholarship {
  id              String       @id @db.Uuid
  universities_id Int
  name            String       @db.VarChar(255)
  description     String?
  deadline        DateTime?    @db.Timestamp(6)
  url_web         String?      @db.VarChar(500)
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  updated_at      DateTime?    @default(now()) @db.Timestamp(6)
  universities    universities @relation(fields: [universities_id], references: [id], onDelete: Cascade)

  @@index([universities_id])
}

model student_academic_profiles {
  student_id             String    @id @db.Uuid
  gpa_transcript_details Json?     @default("{}")
  english_certificates   Json?     @default("{}")
  standardized_tests     Json?     @default("{}")
  updated_at             DateTime? @default(now()) @db.Timestamp(6)
  proof_images           Json?     @default("{}")
  students               students  @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
}

model student_applications {
  id             String            @id @db.Uuid
  user_id        String?           @db.Uuid
  university_id  Int?
  category       SchoolCategory    @default(MATCH)
  status         ApplicationStatus @default(RESEARCHING)
  personal_notes String?
  created_at     DateTime?         @default(now()) @db.Timestamp(6)
  updated_at     DateTime?         @default(now()) @db.Timestamp(6)
  universities   universities?     @relation(fields: [university_id], references: [id], onDelete: Cascade)
  users          users?            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, university_id])
}

model student_backgrounds {
  student_id                    String                          @id @db.Uuid
  created_at                    DateTime?                       @default(now()) @db.Timestamp(6)
  updated_at                    DateTime?                       @default(now()) @db.Timestamp(6)
  experiments                   Json?                           @default("[]")
  academic_awards               academic_awards[]
  academic_extracurriculars     academic_extracurriculars[]
  non_academic_awards           non_academic_awards[]
  non_academic_extracurriculars non_academic_extracurriculars[]
  personal_projects             personal_projects[]
  research_experiences          research_experiences[]
  students                      students                        @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
  subject_scores                subject_scores[]
  work_experiences              work_experiences[]
}

model student_cv_documents {
  id          String   @id @db.Uuid
  student_id  String   @db.Uuid
  file_url    String
  file_name   String   @db.VarChar(255)
  uploaded_at DateTime @default(now()) @db.Timestamp(6)
  students    students @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([student_id])
}

model student_match_school {
  id            String       @id @db.Uuid
  student_id    String       @db.Uuid
  university_id Int
  ai_matching   String       @db.VarChar(50)
  match_score   Decimal?     @db.Decimal(5, 2)
  match_reason  String?
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  updated_at    DateTime?    @default(now()) @db.Timestamp(6)
  students      students     @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
  universities  universities @relation(fields: [university_id], references: [id], onDelete: Cascade)

  @@unique([student_id, university_id], map: "student_match_school_student_university_key")
  @@index([ai_matching])
  @@index([student_id])
  @@index([university_id])
}

model student_parents {
  id           String    @id @db.Uuid
  student_id   String?   @db.Uuid
  full_name    String    @db.VarChar(100)
  relationship String?   @db.VarChar(50)
  phone_number String?   @db.VarChar(20)
  email        String?   @db.VarChar(255)
  job_title    String?   @db.VarChar(150)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  students     students? @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
}

model student_skills {
  id          String    @id @db.Uuid
  student_id  String    @db.Uuid
  skill_name  String    @db.VarChar(150)
  proficiency String?   @db.VarChar(50)
  category    String?   @db.VarChar(50)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  students    students  @relation(fields: [student_id], references: [user_id], onDelete: Cascade)

  @@index([student_id])
}

model student_task_progress {
  id              String           @id @db.Uuid
  student_id      String           @db.Uuid
  task_id         String?          @db.Uuid
  status          TaskStatus       @default(PENDING)
  mentor_note     String?
  completed_at    DateTime?
  created_at      DateTime         @default(now()) @db.Timestamp(6)
  updated_at      DateTime         @default(now()) @db.Timestamp(6)
  submission_url  String?
  deadline        DateTime?        @db.Timestamp(6)
  student_note    String?
  students        students         @relation(fields: [student_id], references: [user_id], onDelete: Cascade)
  checklist_tasks checklist_tasks? @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@unique([student_id, task_id])
}

model students {
  user_id                            String                               @id @db.Uuid
  current_school                     String?                              @db.VarChar(255)
  current_grade                      String?                              @db.VarChar(50)
  current_address                    String?
  talents                            String?
  hobbies                            String?
  yearly_budget                      Decimal?                             @db.Decimal(15, 2)
  personal_desire                    String?
  /// Mục tiêu (1 lần): ngành + trường đã chọn. Chỉ được thiết lập một lần.
  target_faculty_name                String?                              @db.VarChar(255)
  target_university_id               Int?
  target_university_name             String?                              @db.VarChar(500)
  target_set_at                      DateTime?                            @db.Timestamp(6)
  created_at                         DateTime?                            @default(now()) @db.Timestamp(6)
  updated_at                         DateTime?                            @default(now()) @db.Timestamp(6)
  assessments_completed              Boolean?                             @default(false)
  date_of_birth                      DateTime?                            @db.Date
  cv_improve_results                 cv_improve_results?
  essays                             essays[]
  grit_tests                         grit_tests?
  improve_jobs                       improve_jobs[]
  mbti_tests                         mbti_tests?
  mentor_assignments                 mentor_assignments[]
  mentor_custom_deadlines            mentor_custom_deadlines[]
  profile_analyses                   profile_analyses[]
  profile_analysis_jobs              profile_analysis_jobs[]
  profile_improve_results            profile_improve_results[]
  faculty_recommendations            faculty_recommendations[]
  faculty_wishlist                   faculty_wishlist[]
  school_wishlist                    school_wishlist[]
  admission_chance_results           admission_chance_results[]
  riasec_tests                       riasec_tests?
  student_academic_profiles          student_academic_profiles?
  student_backgrounds                student_backgrounds?
  student_cv_documents               student_cv_documents[]
  student_match_school               student_match_school[]
  student_parents                    student_parents[]
  student_skills                     student_skills[]
  student_task_progress              student_task_progress[]
  users                              users                                @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model subject_scores {
  id                  String              @id @db.Uuid
  background_id       String              @db.Uuid
  subject             String              @db.VarChar(100)
  score               Float
  year                Int?
  semester            Int?
  group               String?             @db.VarChar(50)
  created_at          DateTime?           @default(now()) @db.Timestamp(6)
  updated_at          DateTime?           @default(now()) @db.Timestamp(6)
  student_backgrounds student_backgrounds @relation(fields: [background_id], references: [student_id], onDelete: Cascade)

  @@index([background_id])
}

model support_requests {
  id          String   @id @db.Uuid
  student_id  String   @db.Uuid
  description String
  image_url   String?  @db.VarChar(500)
  status      String   @default("PENDING") @db.VarChar(50)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  users       users    @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([status])
  @@index([student_id])
}

model universities {
  id                   Int                    @id @default(autoincrement())
  name                 String                 @db.VarChar(255)
  country              String?                @db.VarChar(100)
  state                String?                @db.VarChar(100)
  current_ranking      Int?
  website_url          String?
  logo_url             String?
  ai_matching_data     Json?                  @default("{}")
  essay_requirements   String?
  scholarship_info     Json?                  @default("{}")
  faculty              faculty[]
  scholarship          scholarship[]
  student_applications student_applications[]
  student_match_school student_match_school[]
}

model users {
  id                    String                  @id @db.Uuid
  full_name             String                  @db.VarChar(100)
  email                 String                  @unique @db.VarChar(255)
  password_hash         String?                 @db.VarChar(255)
  phone_number          String?                 @db.VarChar(20)
  role                  UserRole                @default(STUDENT)
  auth_provider         String?                 @default("LOCAL") @db.VarChar(50)
  auth_provider_id      String?                 @db.VarChar(255)
  avatar_url            String?
  is_active             Boolean?                @default(true)
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  subscription_plan     String?                 @db.VarChar(20)
  subscription_start    DateTime?               @db.Timestamp(6)
  subscription_end      DateTime?               @db.Timestamp(6)
  chat_messages         chat_messages[]
  chat_participants     chat_participants[]
  chat_rooms            chat_rooms[]
  consultation_meetings consultation_meetings[] @relation("MentorMeetings")
  student_meetings      consultation_meetings[] @relation("StudentMeetings")
  essay_comments        essay_comments[]
  mentor_assignments    mentor_assignments[]
  mentors               mentors?
  student_applications  student_applications[]
  students              students?
  support_requests      support_requests[]
}

model verification_tokens {
  id         String   @id @db.Uuid
  identifier String   @db.VarChar(255)
  token      String   @db.VarChar(6)
  expires    DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)

  @@unique([identifier, token])
  @@index([identifier])
}

model work_experiences {
  id                  String              @id @db.Uuid
  background_id       String              @db.Uuid
  company_name        String              @db.VarChar(255)
  job_title           String              @db.VarChar(150)
  employment_type     String?             @db.VarChar(50)
  location            String?             @db.VarChar(255)
  start_date          DateTime?           @db.Date
  end_date            DateTime?           @db.Date
  is_current          Boolean?            @default(false)
  responsibilities    String?
  achievements        String?
  skills_gained       String?
  created_at          DateTime?           @default(now()) @db.Timestamp(6)
  updated_at          DateTime?           @default(now()) @db.Timestamp(6)
  student_backgrounds student_backgrounds @relation(fields: [background_id], references: [student_id], onDelete: Cascade)

  @@index([background_id])
}

model university_rankings {
  id                     Int      @id @default(autoincrement())
  qs_rank                Int      @unique
  name                   String   @db.VarChar(500)
  country                String   @db.VarChar(100)
  country_code           String   @db.VarChar(10)
  city                   String?  @db.VarChar(255)
  region                 String?  @db.VarChar(100)
  type                   String?  @db.VarChar(50)
  founded_year           Int?
  total_students         Int?
  website                String?  @db.VarChar(500)
  qs_overall_score       Float
  academic_reputation    Float
  employer_reputation    Float
  faculty_student_ratio  Float
  citations_per_faculty  Float
  international_faculty  Float
  international_students Float
  strong_subjects        String[]
  description            String?
  school_wishlist        school_wishlist[]
}

enum ApplicationStatus {
  RESEARCHING
  ESSAY_WRITING
  SUBMITTED
  ACCEPTED
  REJECTED
  WAITLISTED
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MentorType {
  AS
  ACS
  ARD
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  LINK
}

enum RoomStatus {
  ACTIVE
  CLOSED
}

enum RoomType {
  PRIVATE
  GROUP
}

enum SchoolCategory {
  REACH
  MATCH
  SAFETY
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  COMPLETED
  NEEDS_REVISION
}

enum TestStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum UserRole {
  STUDENT
  MENTOR
  ADMIN
}
